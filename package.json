{
  "name": "formaldoc",
  "description": "Convert Markdown into professionally formatted DOCX files for Chinese and English documents.",
  "version": "1.16.0",
  "type": "module",
  "files": [
    "dist-package"
  ],
  "main": "./dist-package/src/node.js",
  "types": "./dist-package/src/node.d.ts",
  "exports": {
    ".": {
      "types": "./dist-package/src/node.d.ts",
      "import": "./dist-package/src/node.js"
    },
    "./node": {
      "types": "./dist-package/src/node.d.ts",
      "import": "./dist-package/src/node.js"
    }
  },
  "bin": {
    "formaldoc": "./dist-package/cli/index.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:package && tsc -b && vite build",
    "build:package": "rm -rf dist-package && tsc -p tsconfig.package.json",
    "prepack": "npm run build:package",
    "package:check": "npm run build:package && npm pack --dry-run",
    "preview": "vite preview",
    "lint": "eslint src cli",
    "lint:fix": "eslint src cli --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"cli/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"cli/**/*.ts\"",
    "check": "npm run format && npm run lint && npm run build && npm run test",
    "test": "bun test",
    "test:fast": "bun test src/",
    "test:watch": "bun test --watch",
    "cli": "bun run cli/index.ts",
    "cli:link": "npm run build:package && npm link",
    "thumbnails": "bun run cli/generate-thumbnails.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shrektan/formaldoc.git"
  },
  "homepage": "https://github.com/shrektan/formaldoc#readme",
  "bugs": {
    "url": "https://github.com/shrektan/formaldoc/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "markdown",
    "docx",
    "word",
    "claude",
    "formal-documents",
    "gbt-9704"
  ],
  "dependencies": {
    "@types/katex": "^0.16.7",
    "@types/node": "^22.19.15",
    "@types/turndown": "^5.0.6",
    "@vercel/analytics": "^1.6.1",
    "docx": "^9.5.1",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jsdom": "^26.1.0",
    "katex": "^0.16.27",
    "mathml2omml": "^0.5.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "^1.3.5",
    "@types/file-saver": "^2.0.7",
    "@types/jsdom": "^27.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "vite": "^7.3.0"
  }
}
